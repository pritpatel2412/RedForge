{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/images/(.*)",
      "destination": "/artifacts/redforge/dist/public/images/$1"
    },
    {
      "source": "/favicon.svg",
      "destination": "/artifacts/redforge/dist/public/favicon.svg"
    },
    {
      "source": "/logo.png",
      "destination": "/artifacts/redforge/dist/public/logo.png"
    },
    {
      "source": "/email-logo.png",
      "destination": "/artifacts/redforge/dist/public/email-logo.png"
    },
    {
      "source": "/opengraph.jpg",
      "destination": "/artifacts/redforge/dist/public/opengraph.jpg"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/artifacts/redforge/dist/public/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/redforge/dist/public/index.html"
    }
  ]
}
