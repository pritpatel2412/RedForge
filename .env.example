# ═══════════════════════════════════════════════════
#  RedForge — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════

# ── Database ───────────────────────────────────────
# Neon serverless PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── AI Engine (NVIDIA NIM) ─────────────────────────
# Primary model: zhipuai/glm-5-plus (recommended)
# Fallback model: meta/llama-3.1-70b-instruct (automatic)
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=zhipuai/glm-5-plus

# ── Email (Resend) ─────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Authentication ─────────────────────────────────
SESSION_SECRET=your-long-random-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# GitHub OAuth
GITHUB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin Access ───────────────────────────────────
# Comma-separated emails that are auto-promoted to admin on signup
ADMIN_EMAILS=you@example.com

# ── App URL ────────────────────────────────────────
# Set to your DevTunnel URL during development, production domain in prod
APP_URL=https://your-tunnel-or-domain.com

# ── Stripe (disabled in beta — do not configure) ──
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
