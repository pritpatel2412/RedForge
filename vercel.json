{
  "version": 2,
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "artifacts/api-server/dist/index.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "source": "/(.*)",
      "destination": "artifacts/redforge/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "artifacts/redforge/dist/index.html"
    }
  ]
}
