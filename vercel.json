{
  "version": 2,
  "framework": null,
  "installCommand": "npm i -g pnpm && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/redforge run build",
  "outputDirectory": "artifacts/redforge/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
