{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "dest": "artifacts/redforge/dist/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/redforge/dist/public/index.html"
    }
  ]
}
