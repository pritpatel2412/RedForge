{
  "version": 2,
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "dest": "artifacts/redforge/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/redforge/dist/index.html"
    }
  ]
}
